# Base URL of the deployed site. Used for cookie domain scoping, absolute
# links in emails, sitemap.xml, robots.txt, and OAuth redirect URLs.
# Use http://localhost:3000 for local development.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase project URL and anon (public) key. Safe to expose to the browser —
# access is enforced by Row Level Security policies, not by key secrecy.
# Find both in Supabase Dashboard -> Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase service role key. Bypasses Row Level Security — server-side only,
# never expose to the browser. Used for admin-only operations.
# Find in Supabase Dashboard -> Project Settings -> API.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Email address granted access to /admin. Must match the email of an
# existing authenticated user's account.
ADMIN_EMAIL=admin@example.com

# Resend API key, used to send OTP verification emails (app/api/send-otp).
# Get one at https://resend.com/api-keys.
RESEND_API_KEY=your_resend_api_key
